frame_counters = {name: 0     for name in models}
last_ordered   = {name: []    for name in models}
last_f1s       = {name: {}    for name in models}

with ZedCamera() as zed:
    while True:
        frame, _, _ = zed.get_color_and_depth_frame()
        if frame.shape[2] == 4:
            frame = cv2.cvtColor(frame, cv2.COLOR_BGRA2BGR)
        orig = frame.copy()
        h0,w0 = orig.shape[:2]

        # 밝은 영역 블러링
        gray = cv2.cvtColor(orig, cv2.COLOR_BGR2GRAY)
        _, mask = cv2.threshold(gray,150,255,cv2.THRESH_BINARY)
        blur = cv2.GaussianBlur(orig,(5,5),0)
