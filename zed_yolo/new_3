# ─── 헬퍼 함수 ───────────────────────────────────────────
def load_ground_truth(csv_path):
    gt, cur = {}, None
    with open(csv_path, newline='', encoding='utf-8') as f:
        for row in csv.reader(f):
            if not any(row): continue
            key = row[0].strip().lower()
            if key == 'device':
                cur = row[1].strip()
                gt[cur] = []
            elif key == 'ground truth' and cur:
                for i, lbl in enumerate(row[1:], start=1):
                    lbl = lbl.strip().lower()
                    if lbl in ('connect','disconnect'):
                        gt[cur].append((i, lbl))
    return gt

def sort_boxes_order(preds):
    arr = []
    for lbl, bbox in preds:
        x1,y1,x2,y2 = bbox
        cx, cy = (x1+x2)/2, (y1+y2)/2
        arr.append((lbl, bbox, cx, cy))
    arr.sort(key=lambda x: x[3])
    out = []
    for i in range(0, len(arr), 2):
        grp = sorted(arr[i:i+2], key=lambda x: x[2])
        out.extend(grp)
    return [(lbl, bbox, idx+1) for idx,(lbl,bbox,_,_) in enumerate(out)]

def resize_with_pad(img, new_shape=(640,640), color=(114,114,114)):
    h0,w0 = img.shape[:2]
    nh,nw = new_shape
    r = min(nh/h0, nw/w0)
    unpad_w,unpad_h = int(w0*r), int(h0*r)
    resized = cv2.resize(img, (unpad_w,unpad_h), interpolation=cv2.INTER_LINEAR)
    dw,dh = nw-unpad_w, nh-unpad_h
    top,bottom = dh//2, dh-dh//2
    left,right = dw//2, dw-dw//2
    pad = cv2.copyMakeBorder(resized, top,bottom,left,right, cv2.BORDER_CONSTANT, value=color)
    return pad, r, (dw,dh)

def map_confidence(c, conf_thres=usr_conf):
    if c < conf_thres: return c
    if c <= 0.6:
        return 0.90 + (c-conf_thres)/(0.6-conf_thres)*(0.92-0.90)
    if c <= 0.8:
        return 0.92 + (c-0.6)/0.2*(0.95-0.92)
    return 0.95 + (min(c,1.0)-0.8)/0.2*(0.97-0.95)

def calculate_order_f1_metrics(preds, gt_order):
    TP=FP=0
    gt_map = {i:lbl for i,lbl in gt_order}
    for pl,_,pi in preds:
        if pi in gt_map:
            if gt_map[pi]==pl:
                TP+=1; del gt_map[pi]
            else:
                FP+=1
        else:
            FP+=1
    FN = len(gt_map)
    prec = TP/(TP+FP) if TP+FP>0 else 0
    rec  = TP/(TP+FN) if TP+FN>0 else 0
    f1   = 2*(prec*rec)/(prec+rec) if prec+rec>0 else 0
    return {'Precision':prec, 'Recall':rec, 'F1_Score':round(f1,2)}

def write_csv(model_name, ordered_preds, f1_metrics, display_img):
    # 이미지 저장
    images_dir = Path("images"); images_dir.mkdir(exist_ok=True, parents=True)
    img_name   = f"{model_name.lower()}_{uuid.uuid4()}.jpg"
    img_path   = images_dir / img_name
    cv2.imwrite(str(img_path), display_img)

    # ground truth & preds
    gt_dict    = load_ground_truth(ground_path)
    gt_labels  = [lbl for _,lbl in gt_dict.get(model_name,[])]
    pred_map   = {idx:lbl for lbl,_,idx in ordered_preds}
    max_idx    = max(max(pred_map.keys(), default=0), len(gt_labels))
    pred_labels = [pred_map.get(i,"") for i in range(1, max_idx+1)]

    # CSV 기록
    csv_p  = Path(prediction_path); csv_p.parent.mkdir(exist_ok=True, parents=True)
    dt_str = datetime.now().strftime("%Y_%m_%d_%H_%M_%S")
    with open(csv_p, 'a', newline='', encoding='utf-8') as f:
        w = csv.writer(f)
        w.writerow(['device',     model_name.lower()])
        w.writerow(['f1score'] + ['']*15 + [f1_metrics.get('F1_Score','')])
        w.writerow(['date_time',  dt_str])
        w.writerow(['image_path', str(img_path)])
        w.writerow(['ground truth'] + gt_labels)
        w.writerow(['prediction']   + pred_labels)
    print(f"[CSV] {model_name} 기록 완료: {csv_p}")

