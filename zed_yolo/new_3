        annotated = feed.copy()

        # 모든 모델에 대해 탐지 & 그리기
        for name,info in models.items():
            mdl, names, col = info['model'], info['names'], info['color']
            img1, _, _ = resize_with_pad(feed,(640,640))
            tensor = (torch.from_numpy(img1[:,:,::-1].transpose(2,0,1))
                         .to(device).float().unsqueeze(0)/255.0)
            with torch.no_grad():
                pred = mdl(tensor, augment=False, visualize=False)
                pred = non_max_suppression(pred, conf_thres=usr_conf, iou_thres=0.45)[0]
            dets=[]
            if pred is not None and len(pred):
                pred[:,:4] = scale_boxes((640,640), pred[:,:4], (h0,w0)).round()
                an = Annotator(annotated, line_width=2, example=str(names))
